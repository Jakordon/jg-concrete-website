<nav class="nav">
  <div class="container nav-inner">
    <a href="#" class="logo">
      <img src="/images/Clear bg Logo.png" alt="JG Concrete" class="logo-img" />
      <span class="logo-text">JG <strong>Concrete</strong></span>
    </a>
    <div class="nav-right">
      <a href="#services" class="nav-link">Services</a>
      <a href="#about" class="nav-link">About</a>
      <a href="#portfolio" class="nav-link">Portfolio</a>
      <a href="tel:4697044227" class="nav-phone">(469) 704-4227</a>
      <a href="#quote" class="btn btn-primary">Free Quote</a>
    </div>
    <button class="nav-toggle" aria-label="Open menu">&#9776;</button>
  </div>
  <div class="nav-mobile">
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#portfolio">Portfolio</a>
    <a href="#reviews">Reviews</a>
    <a href="#quote">Free Quote</a>
    <a href="tel:4697044227">(469) 704-4227</a>
  </div>
</nav>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const mobileNav = document.querySelector('.nav-mobile');
  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => mobileNav.classList.toggle('open'));
    mobileNav.querySelectorAll('a').forEach(link =>
      link.addEventListener('click', () => mobileNav.classList.remove('open'))
    );
  }
</script>
